RewriteEngine On

# Don't rewrite requests already pointing to /out/
RewriteCond %{REQUEST_URI} ^/out/
RewriteRule ^ - [L]

# Don't expose .git
RewriteCond %{REQUEST_URI} ^/\.git
RewriteRule ^ - [F,L]

# If the request ends with a trailing slash, serve index.html from /out/
RewriteCond %{REQUEST_URI} /$
RewriteCond %{DOCUMENT_ROOT}/out%{REQUEST_URI}index.html -f
RewriteRule ^(.*)$ /out/$1index.html [L]

# If the request maps to an actual file in /out/, serve it directly
RewriteCond %{DOCUMENT_ROOT}/out/%{REQUEST_URI} -f
RewriteRule ^(.*)$ /out/$1 [L]

# If the request is a directory without trailing slash, add the trailing slash
RewriteCond %{DOCUMENT_ROOT}/out%{REQUEST_URI}/ -d
RewriteCond %{REQUEST_URI} !/$
RewriteRule ^(.*)$ /$1/ [R=301,L]

# Fallback: try serving from /out/ (for _next assets, etc.)
RewriteRule ^(.*)$ /out/$1 [L]

# Ensure proper MIME types for Next.js assets
<IfModule mod_mime.c>
  AddType application/javascript .js
  AddType text/css .css
  AddType application/json .json
  AddType text/plain .txt
</IfModule>

# Enable gzip compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json text/plain
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
</IfModule>
